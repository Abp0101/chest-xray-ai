# .env.example
# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.
#
# The Kaggle API key does NOT go here — it lives at ~/.kaggle/kaggle.json
# (the Kaggle CLI reads it automatically from that path).

# Weights & Biases — get your key at https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# Optional: set to "disabled" to turn off wandb logging during development
# WANDB_MODE=disabled
